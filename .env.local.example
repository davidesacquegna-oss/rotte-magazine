# URL del tuo backend Strapi
# In sviluppo locale:
NEXT_PUBLIC_STRAPI_URL=http://localhost:1337

# In produzione, sostituisci con il tuo dominio:
# NEXT_PUBLIC_STRAPI_URL=https://cms.rottemagazine.it

# Opzionale: API Token Strapi (se hai endpoint protetti)
# Crea un token in Strapi Admin → Settings → API Tokens
# STRAPI_API_TOKEN=your_token_here
